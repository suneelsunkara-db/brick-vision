# BrickVision local dev config — copy to .env (git-ignored) and fill in.
# Loader precedence: .env → environment variables → DAB variables (deployed).
# Loader REFUSES to start with BV_MODE=prod + .env present.

# --- Databricks workspace connection ---
DATABRICKS_HOST=                                      # https://<workspace-host>
DATABRICKS_TOKEN=                                    # PAT or OAuth token for local deploy; never commit real values
DATABRICKS_WAREHOUSE_ID=                             # serverless SQL warehouse — REQUIRED for all SQL execution
                                                                      # NOTE: every BrickVision compute path is Databricks Serverless
                                                                      # per discipline rule 12 (docs/01-overview.md §0).
                                                                      # SQL → serverless warehouse, batch → serverless Jobs,
                                                                      # Apps → serverless Apps, model serving → Mosaic AI serverless.
                                                                      # No all-purpose or job clusters anywhere.

# --- BrickVision install scope (1 catalog + 1 schema; flat namespace) ---
# Every BrickVision UC object lives under <BV_CATALOG>.<BV_SCHEMA>.<table>.
# There are no sub-schemas (audit/config/kg/etc. are gone v0.7.7); every
# table sits in the single BV_SCHEMA, identified by a globally-unique
# table name. One OWNER, one set of grants, one DROP SCHEMA CASCADE on
# uninstall.
BV_CATALOG=brickvision_catalog
BV_SCHEMA=brickvision
BV_VS_ENDPOINT=bv_vs_endpoint

# --- Mode + test-control flags (the only env knobs the runtime reads) ---
BV_MODE=local                                        # local | dev | stg | prod
BV_DRY_RUN=false                                      # true = no UC/Delta writes, only log
BV_FAKE_LLM=false                                    # true = use canned LLM fixtures from tests/fixtures/

# --- Local deploy (v0.7.7 — scripts/local_deploy.sh) ---
# These knobs drive `scripts/local_deploy.sh`, the one-shot script that
# auto-provisions the workspace-side prerequisites for running the
# capability indexer end-to-end against a real Databricks workspace
# while keeping the SPA + FastAPI sidecar local. Topology:
#
#   - SPA + sidecar:           runs locally (this machine)
#   - Indexer Job:             runs in Databricks workspace, 14 tasks
#                              (T01-T13 index into Delta; T14 publishes
#                               the capability graph to Lakebase)
#   - UC tables (state):       live in <BV_CATALOG>.<BV_SCHEMA>.* (Delta only)
#   - UC Volume (inter-task):  <BV_CATALOG>.<BV_SCHEMA>.<BV_INDEXER_STATE_VOLUME>
#                              (per-run JSON hand-off between the 14 indexer
#                               tasks; NOT used as a state store)
#   - VS endpoint:             BV_VS_ENDPOINT (workspace-wide)
#   - Lakebase project:        <BV_LAKEBASE_PROJECT_ID> (Autoscaling Postgres
#                              project; UI reads from here for low-latency
#                              OLTP queries; populated by T14 publish task)
#   - Service principals:      bv_indexer_sp + bv_app_sp
#
# Run order:
#   1. Fill in DATABRICKS_HOST + DATABRICKS_TOKEN above (workspace
#      admin + metastore admin token; PAT or OAuth profile).
#   2. cp .env.example .env && vim .env                   (do not commit)
#   3. bash scripts/local_deploy.sh                        (~12-15 min)
#   4. bash scripts/local_deploy/start_local_spa.sh        (separate terminal)
#   5. Open http://localhost:5173/knowledge in your browser.
BV_LOCAL_DEPLOY_INDEXER_SP_NAME=bv_indexer_sp        # SCIM display_name; idempotent
BV_LOCAL_DEPLOY_APP_SP_NAME=bv_app_sp                # SCIM display_name; idempotent
BV_LOCAL_DEPLOY_AUTO_PROVISION_SPS=true              # set false to skip SP creation
BV_LOCAL_DEPLOY_AUTO_PROVISION_CATALOG=true          # set false to skip catalog/schema creation
BV_LOCAL_DEPLOY_AUTO_PROVISION_VS=true               # set false to skip VS endpoint+index creation (~10 min cold)
BV_LOCAL_DEPLOY_AUTO_PROVISION_WAREHOUSE=true        # creates `bv-warehouse` if DATABRICKS_WAREHOUSE_ID is empty
BV_LOCAL_DEPLOY_DEPLOY_INDEXER_JOB=true              # set false to skip `databricks bundle deploy`
BV_LOCAL_DEPLOY_TRIGGER_FIRST_REFRESH=true           # set false to inspect deployment before triggering compute
BV_LOCAL_DEPLOY_VS_ENDPOINT_TIMEOUT_SEC=900          # max wait for VS endpoint ONLINE (~10-15 min cold)
BV_LOCAL_DEPLOY_INDEXER_TIMEOUT_SEC=2400             # max wait for first refresh end-to-end (~15-30 min)
BV_LOCAL_DEPLOY_OPS_EMAIL=                           # email for indexer Job-failure notifications
BV_LOCAL_DEPLOY_LOG_PATH=./local_deploy.log          # idempotent log file (script appends)

# --- Databricks Capability Graph indexer (v0.7.7) ---
# Multi-task serverless Databricks Job that crawls SDK + OpenAPI + docs +
# blogs + Lakebridge labs nightly, builds the 3-level Top-Order /
# Meta-Skill / Extension taxonomy, and syncs Mosaic AI Vector Search
# indexes. See docs/23-databricks-capability-graph.md.
BV_INDEXER_FRESHNESS_TOLERANCE_DAYS=2                # Stage A surfaces CAPABILITY_GRAPH_SNAPSHOT_STALE past this
LLM_GENERAL_TASKS=databricks-qwen3-next-80b-a3b-instruct
LLM_EMBEDDING_TASKS=databricks-qwen3-embedding-0-6b
BV_INDEXER_DAILY_TOKEN_CAP=10000000                  # hard cap; aborts the indexer DAG when exceeded
BV_INDEXER_DAILY_EMBEDDING_BUDGET_USD=5              # advisory; emits Question at 80%, never aborts
BV_INDEXER_DISABLE_BLOG=true                         # disable blog source indexing (cleanup: blog chunks pollute data)
BV_INDEXER_STATE_VOLUME=indexerstate                # UC Volume name (NOT a state store) used as the per-run
                                                     # JSON hand-off channel between the 14 indexer tasks.
                                                     # Resolves to /Volumes/<BV_CATALOG>/<BV_SCHEMA>/<this>/runs/<run_id>/.
                                                     # Renamed from `indexer` in v0.7.7 to make the not-state
                                                     # role explicit; install pre-flight + retention sweep
                                                     # both honour the override.
BV_SQL_TRANSPILE_SOURCE_PATH=                       # optional UC Volume directory for Lakebridge llm-transpile SQL source
BV_SQL_TRANSPILE_SOURCE_FILENAME=                   # optional SQL file name inside BV_SQL_TRANSPILE_SOURCE_PATH
BV_SQL_TRANSPILE_SOURCE_FILE=                       # optional full /Volumes/.../*.sql source file override
BV_SQL_TRANSPILE_OUTPUT_PATH=                       # optional UC Volume directory for Lakebridge Switch SQL output
BV_SQL_TRANSPILE_SWITCH_CONFIG_PATH=                # optional /Volumes/... Switch config YAML override for llm-transpile
BV_CODE_CONVERT_SWITCH_CONFIG_PATH=                 # optional /Volumes/... Switch config YAML override for Code Convert

# --- BrickVision Evaluation (MLflow + UC eval datasets) ---
# Local deploy uploads scripts/run_evaluation_scorers.py,
# scripts/sync_mlflow_eval_datasets.py, and config/evaluation/* to the
# Databricks workspace and deploys the bv_evaluation_scorers serverless Job.
BV_EVALUATION_SCHEDULE_CRON=0 0 4 * * ?             # daily 04:00 UTC, after indexer/workspace refresh windows
BV_EVALUATION_WAREHOUSE_ID=                         # defaults to DATABRICKS_WAREHOUSE_ID when empty
BV_MLFLOW_EVALUATION_EXPERIMENT_ID=                 # required for live eval dataset sync / MLflow Agent Evaluation runs
BV_EVALUATION_JOB_NAME=bv_evaluation_scorers        # CLI lookup name for `brickvision evaluation run`

# --- Databricks Lakebase Autoscaling (capability-graph read substrate, v0.7.7) ---
# Lakebase Autoscaling is the OLTP-side read substrate for the Knowledge UI:
# the indexer Job's T14 publish task creates Synced Tables for the 7 UI-facing
# capability-graph tables; the FastAPI sidecar reads those Synced Tables via
# psycopg for low-latency page loads. See:
#   https://docs.databricks.com/aws/en/oltp/projects/get-started
#   https://docs.databricks.com/aws/en/oltp/projects/sync-tables
#
# Synced tables live at <BV_CATALOG>.<BV_SCHEMA>.<table>_synced (same UC
# catalog/schema as the source Delta — there is no Lakebase-typed UC catalog).
# The Postgres-side schema auto-equals BV_SCHEMA.
#
# The Lakebase project + branch + database must be created in the Databricks UI
# (Lakebase Apps → Autoscaling → New project) before the indexer can publish.
# When unset, T14 publish becomes a structured no-op and the Knowledge UI
# tabs render the "indexer not yet run" empty state.
BV_LAKEBASE_PROJECT_ID=brickvision_lakebase          # Lakebase Autoscaling project name (visible in Lakebase Apps UI).
                                                     # Leave empty to disable Lakebase reads (UI shows empty state
                                                     # and T14 publish becomes a structured no-op).
BV_LAKEBASE_HOST=                                    # optional direct Postgres host from Lakebase Connect / CLI.
BV_LAKEBASE_ENDPOINT_NAME=                           # optional endpoint name: projects/<id>/branches/<id>/endpoints/<id>.
BV_LAKEBASE_PRINCIPAL=                               # Postgres OAuth role / service-principal client ID (same as PGUSER).
BV_LAKEBASE_BRANCH=production                        # branch within the project; doc default is `production`
BV_LAKEBASE_DATABASE=databricks_postgres             # Postgres database within the branch; doc default is `databricks_postgres`
BV_LAKEBASE_SYNC_MODE=snapshot                       # `snapshot` (one-shot per promote — DEFAULT, matches the atomic-promote lifecycle)
                                                     # `triggered` (refresh on demand)
                                                     # `continuous` (CDC; extra cost, not needed for nightly refresh)
                                                     #
                                                     # Prefer BV_LAKEBASE_HOST + BV_LAKEBASE_ENDPOINT_NAME for direct
                                                     # Postgres connection. Without those, the host/endpoint is resolved
                                                     # once via WorkspaceClient.postgres.list_endpoints(...). Postgres
                                                     # port is always 5432.
